{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mikanbox",
  "version": "0.1.0",
  "identifier": "com.vaciller.mikanbox",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1520",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "mikanbox",
        "width": 1360,
        "height": 820,
        "resizable": false,
        "maximizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/aria2c", "binaries/mkvmerge"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
