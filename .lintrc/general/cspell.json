{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en",

  "words": [],

  "flagWords": [
    "hte",
    "teh",
    "recieve",
    "occured",
    "doesnt",
    "cant",
    "dont",
    "couldnt",
    "shouldnt",
    "wont",
    "wouldnt",
    "isnt",
    "wasnt",
    "werent",
    "arent",
    "havent",
    "hasnt",
    "hadnt",
    "neednt"
  ],

  "dictionaries": [
    "en_US",
    "companies",
    "softwareTerms",
    "misc",
    "filetypes",
    "typescript",
    "node",
    "npm",
    "bash",
    "git",
    "markdown"
  ],

  "ignorePaths": [
    ".git",
    ".git/**",
    "**/.git",
    "**/.git/**",
    "yarn.lock",
    "package-lock.json",
    "Cargo.lock",
    "src-tauri/target/**",
    "LICENSE"
  ],

  "overrides": [
    {
      "filename": "**/*.{ts,tsx}",
      "dictionaries": ["typescript", "node", "npm"]
    },
    {
      "filename": "**/*.{yaml,yml}",
      "words": []
    },
    {
      "filename": "**/*.{md,mdx}",
      "words": []
    },
    {
      "filename": "**/README.md",
      "flagWords": []
    }
  ],

  "enableGlobDot": true,
  "useGitignore": true,
  "maxNumberOfProblems": 50,
  "minWordLength": 4
}
