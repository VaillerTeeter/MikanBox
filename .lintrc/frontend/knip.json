{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "entry": ["src/main.tsx", "vite.config.ts"],

  "project": ["src/**/*.{ts,tsx}", "vite.config.ts"],

  "ignore": [],

  "ignoreDependencies": ["@commitlint/types"],

  "ignoreBinaries": ["commitlint", "cspell", "eslint", "prettier", "tauri"],

  "includeEntryExports": false,

  "exclude": [],

  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "optionalPeerDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "error",
    "nsExports": "error",
    "classMembers": "error",
    "types": "error",
    "nsTypes": "error",
    "enumMembers": "error",
    "duplicates": "error"
  }
}
